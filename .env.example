# ──────────────────────────────────────────────
# MCP_NodeServer 環境變數
# 複製此檔為 .env 後依本機環境修改
# .env 已加入 .gitignore，不進版控
# ──────────────────────────────────────────────

# ── MCP Server ────────────────────────────────

# 允許 MCP 工具存取的根目錄（逗號分隔多個）
# 相對路徑的檔案操作會以第一個為基準
MCP_BASE_PATHS=D:\Project\

# ── Hook: repetition-detector ─────────────────

# 啟用 hook 除錯日誌（stderr 輸出 [hook-debug] 標籤）
CLAUDE_HOOK_DEBUG=0

# Slack webhook URL，阻擋事件時發送通知（選填）
CLAUDE_SLACK_WEBHOOK=

# 僅在阻擋（block）事件時發送 Slack 通知（1=僅阻擋, 0=所有警告）
CLAUDE_NOTIFY_ON_BLOCK=1

# Token 浪費回饋模式：active=逐次即時提醒, passive=定期累計摘要
# active  — 適合小 context，及早省 token
# passive — 適合 Pro Max 1M context，低干擾，定期報告
CLAUDE_TOKEN_FEEDBACK=passive

# 被動模式下，每 N 次 tool call 輸出一次效率摘要（預設 25）
CLAUDE_SUMMARY_INTERVAL=25
